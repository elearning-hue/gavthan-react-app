# Copy to .env and fill in. Only VITE_-prefixed vars reach the client bundle.
# NOTE: the Supabase anon key and Google client ID are public by design (they
# ship in any client app). Real secrets live server-side in Edge Functions.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# UPI payment id shown on bills — leave blank to disable the UPI link
VITE_UPI_ID=yourname@upi

VITE_HOTEL_NAME=Gavthan
VITE_PARTNER_DISCOUNT=0

# Google OAuth client id for Drive backup (optional — blank disables Drive)
VITE_GOOGLE_CLIENT_ID=

# Comma-separated emails that get Admin role; everyone else is Staff
VITE_ADMIN_EMAILS=admin1@example.com,admin2@example.com
